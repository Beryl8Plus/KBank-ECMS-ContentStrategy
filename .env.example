# ─────────────────────────────────────────────
# Environment
# DEVLOCAL  → local dev (plain Redis, no TLS/Workload Identity)
# (unset)   → production / AKS (Azure Workload Identity, Redis Entra auth)
# ─────────────────────────────────────────────
SETENV=DEVLOCAL
PREFIX_CONTENT_STRATEGY_API_V1=/api/content-strategy/v1/

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=kbank_ecms
DB_SSLMODE=disable

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Azure Managed Identity principal ID for Redis Entra authentication
# Required when SETENV != DEVLOCAL
REDIS_PRINCIPAL_ID=

# ─────────────────────────────────────────────
# Azure Storage (Azure Files)
# ─────────────────────────────────────────────
AZACCOUNTNAME=
SHARENAME=

# ─────────────────────────────────────────────
# Swagger UI
# Override the host shown in swagger UI (e.g. api.example.com)
# Defaults to localhost:8081 when unset
# ─────────────────────────────────────────────
SWAGGER_HOST=

# ─────────────────────────────────────────────
# Cache TTLs
# ─────────────────────────────────────────────
CMS_RUNTIME_TTL=15m
CMS_RUNTIME_INTERVAL=5m

# ─────────────────────────────────────────────
# CLEN Lead Information API
# Leave CLEN_LEAD_API_BASE_URL / CLEN_LEAD_API_KEY empty to disable CLEN
# enrichment (delivery service still boots and serves non-lead traffic).
# Example DEV upstream:
#   https://apimdataappseadev002.dataappintn.kasikornbank.com/clen/core-lead-info-inquiry
# ─────────────────────────────────────────────
CLEN_LEAD_API_BASE_URL=
# Request path appended to BaseURL (default: /v1/leads/customer-level)
CLEN_LEAD_API_PATH=/v1/leads/customer-level
CLEN_LEAD_API_KEY=
CLEN_LEAD_APP_ID=845
CLEN_LEAD_API_TIMEOUT=5s
CLEN_LEAD_API_RETRIES=2
CLEN_LEAD_CACHE_TTL=1h
# exp_f query param sent to CLEN.
#   true  (default when unset) — only non-expired leads
#   false                        — only expired leads
#   none                         — omit param, CLEN returns both
CLEN_LEAD_EXP_F=true

# ─────────────────────────────────────────────
# CLEN Customer Profile (Dynamic Query) API
# Leave CLEN_CUSTOMER_PROFILE_API_BASE_URL / KEY empty to disable.
# Example DEV upstream:
#   https://apimdataappseadev002.dataappintn.kasikornbank.com/clen/customer-inquiry
# ─────────────────────────────────────────────
CLEN_CUSTOMER_PROFILE_API_BASE_URL=
# Request path appended to BaseURL (default: /v1/customers/query)
CLEN_CUSTOMER_PROFILE_API_PATH=/v1/customers/query
CLEN_CUSTOMER_PROFILE_API_KEY=
CLEN_CUSTOMER_PROFILE_APP_ID=
CLEN_CUSTOMER_PROFILE_API_TIMEOUT=5s
CLEN_CUSTOMER_PROFILE_API_RETRIES=2
CLEN_CUSTOMER_PROFILE_CACHE_TTL=1h

# ─────────────────────────────────────────────
# Logger
# ─────────────────────────────────────────────
