# ─────────────────────────────────────────────
# Environment
# DEVLOCAL  → local dev (plain Redis, no TLS/Workload Identity)
# (unset)   → production / AKS (Azure Workload Identity, Redis Entra auth)
# ─────────────────────────────────────────────
SETENV=DEVLOCAL

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=kbank_ecms
DB_SSLMODE=disable

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Azure Managed Identity principal ID for Redis Entra authentication
# Required when SETENV != DEVLOCAL
REDIS_PRINCIPAL_ID=

# ─────────────────────────────────────────────
# Azure Storage (Azure Files)
# ─────────────────────────────────────────────
AZACCOUNTNAME=
SHARENAME=

# ─────────────────────────────────────────────
# Swagger UI
# Override the host shown in swagger UI (e.g. api.example.com)
# Defaults to localhost:8081 when unset
# ─────────────────────────────────────────────
SWAGGER_HOST=

# ─────────────────────────────────────────────
# gRPC (inter-service communication)
# ─────────────────────────────────────────────
CMS_RUNTIME_GRPC_PORT=50051
CMS_RUNTIME_GRPC_ADDR=localhost:50051

# ─────────────────────────────────────────────
# Cache TTLs
# ─────────────────────────────────────────────
CMS_RUNTIME_TTL=15m
CMS_RUNTIME_INTERVAL=5m

# ─────────────────────────────────────────────
# Logger
# ─────────────────────────────────────────────
