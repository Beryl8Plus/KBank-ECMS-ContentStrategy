# ─────────────────────────────────────────────
# .env.backoffice.example
# Environment variables for Server A (Backoffice)
# Copy to .env.backoffice and fill in production values
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# Environment
# ─────────────────────────────────────────────
# Leave empty or unset for production (enables Azure Workload Identity, Redis Entra auth)
# SETENV=DEVLOCAL

# ─────────────────────────────────────────────
# PostgreSQL (runs locally on this server)
# ─────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=kbank_ecms
DB_SSLMODE=disable

# ─────────────────────────────────────────────
# Redis (runs locally on this server)
# ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Azure Managed Identity principal ID for Redis Entra authentication
# Required when SETENV != DEVLOCAL
REDIS_PRINCIPAL_ID=

# ─────────────────────────────────────────────
# Azure Storage (Azure Files)
# ─────────────────────────────────────────────
AZACCOUNTNAME=
SHARENAME=

# ─────────────────────────────────────────────
# Swagger UI
# ─────────────────────────────────────────────
SWAGGER_HOST=backoffice-api.example.com

# ─────────────────────────────────────────────
# gRPC (inter-service communication)
# ─────────────────────────────────────────────
CMS_RUNTIME_GRPC_PORT=50051
CMS_RUNTIME_GRPC_ADDR=localhost:50051
