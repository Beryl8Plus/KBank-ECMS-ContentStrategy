# ─────────────────────────────────────────────
# .env.delivery.example
# Environment variables for Server B (Delivery)
# Copy to .env.delivery and fill in production values
# ─────────────────────────────────────────────
#
# IMPORTANT: DB_HOST and REDIS_HOST must point to Server A's IP/hostname
# since Postgres and Redis run on Server A.
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# Environment
# ─────────────────────────────────────────────
# Leave empty or unset for production (enables Azure Workload Identity, Redis Entra auth)
# SETENV=DEVLOCAL

# ─────────────────────────────────────────────
# PostgreSQL (remote — runs on Server A)
# ─────────────────────────────────────────────
DB_HOST=SERVER_A_IP_OR_HOSTNAME
DB_PORT=5432
DB_USER=delivery_readonly
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=kbank_ecms
DB_SSLMODE=require

# ─────────────────────────────────────────────
# Redis (remote — runs on Server A, shared instance)
# Required for: cache reads + Pub/Sub subscription (cms:sync:ping)
# ─────────────────────────────────────────────
REDIS_HOST=SERVER_A_IP_OR_HOSTNAME
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Azure Managed Identity principal ID for Redis Entra authentication
# Required when SETENV != DEVLOCAL
REDIS_PRINCIPAL_ID=

# ─────────────────────────────────────────────
# Swagger UI
# ─────────────────────────────────────────────
SWAGGER_HOST=delivery-api.example.com

# ─────────────────────────────────────────────
# Cache TTLs
# ─────────────────────────────────────────────
CMS_RUNTIME_TTL=15m
CMS_RUNTIME_INTERVAL=5m
